# Backend Configuration

# Server Port
PORT=5000

# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/heartconnect_users

# JWT Configuration
JWT_SECRET=your-very-secure-random-secret-key-here
JWT_EXPIRE=7d

# Browser origins allowed by CORS in production (comma-separated).
# Include BOTH the Vercel frontend URL and any custom domains.
# Production should use https:// (TLS). Example:
#   CLIENT_URL=https://heartconnect.vercel.app,https://www.heartconnect.com
CLIENT_URL=http://localhost:5173

# Environment (development | staging | production)
NODE_ENV=development

# Email (SMTP) — optional; required only if you use email features (2FA/reset).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM=HeartConnect <your-email@example.com>
