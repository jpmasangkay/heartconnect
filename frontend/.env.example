# Frontend Configuration
# These are exposed to the browser — never put secrets here.

# Backend API base URL (must include /api path).
# LOCAL DEV:  http://localhost:5000/api
# PRODUCTION: https://your-app.onrender.com/api  (your Render URL)
VITE_API_URL=http://localhost:5000/api

# Backend Socket.io URL (root origin, no /api).
# LOCAL DEV:  http://localhost:5000
# PRODUCTION: https://your-app.onrender.com  (your Render URL)
VITE_SOCKET_URL=http://localhost:5000
