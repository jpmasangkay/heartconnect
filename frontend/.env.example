# Frontend Configuration
# These are exposed to the browser — never put secrets here.

# Backend API base URL (must include /api path).
# LOCAL DEV:  http://localhost:5000/api  (direct to backend)
# PRODUCTION: /api                       (goes through Vercel proxy rewrite)
VITE_API_URL=http://localhost:5000/api

# Backend Socket.io URL (root origin, no /api).
# Socket.io always connects directly to the backend server.
# LOCAL DEV:  http://localhost:5000
# PRODUCTION: https://your-app.onrender.com  (your Render URL)
VITE_SOCKET_URL=http://localhost:5000

# ─── Vercel-only (set in Vercel project dashboard, NOT in .env) ──────────────
# BACKEND_URL — the full Render backend origin, used by vercel.json rewrites.
# Example: https://heartconnect-api.onrender.com
# Set this in: Vercel → Project Settings → Environment Variables
